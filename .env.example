# Copy to .env in production and fill real values. Compose auto-loads .env for
# ${VAR} interpolation in docker-compose.yml; dev needs none of this (the
# ${VAR:-default} values in compose apply). .env is gitignored; this template
# is committed as documentation.

# Postgres credentials feed both the db service and the API DATABASE_URL.
POSTGRES_USER=qafiyah
POSTGRES_PASSWORD=qafiyah
POSTGRES_DB=qafiyah

# API runtime environment tag (optional; defaults to production in compose).
ENVIRONMENT=production
