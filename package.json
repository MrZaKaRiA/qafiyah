{
  "name": "qafiyah",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "db:setup": "./dev/setup-database.sh",
    "clean:dev": "pkill -f 'qafiyah/.*(astro|wrangler|workerd)' || true",
    "preinstall": "node -e \"if(!String(process.env.npm_config_user_agent||'').startsWith('pnpm/')){console.error('Use pnpm (npm/yarn not supported). Try: corepack pnpm install');process.exit(1)}\"",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "types": "turbo run types",
    "lint": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx}\"",
    "test": "turbo run test",
    "knip": "knip",
    "madge": "madge --circular --extensions ts,tsx,js,jsx apps packages",
    "ci": "pnpm run format && pnpm run lint && pnpm run types && pnpm run test && pnpm run knip && pnpm run madge"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/types": "^19.6.0",
    "@types/node": "^25.0.10",
    "husky": "^9.1.7",
    "knip": "^5.82.1",
    "madge": "8.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
