{
  "name": "qafiyah",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "./scripts/dev.sh",
    "up": "docker compose up -d --build",
    "down": "docker compose down",
    "es:up": "docker compose up -d --wait elasticsearch",
    "es:down": "docker compose stop elasticsearch",
    "reindex": "./scripts/es-reindex.sh",
    "db:up": "docker compose up -d --wait db",
    "db:reset": "docker compose down -v && docker compose up -d --wait db",
    "clean": "pkill -f 'qafiyah/.*astro' || true; pkill -f 'apps/api/src/server.ts' || true",
    "build": "turbo run build",
    "types": "turbo run types",
    "lint": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx}\"",
    "test": "turbo run test",
    "smoke": "bun scripts/smoke-test.ts",
    "knip": "knip",
    "madge": "madge --circular --extensions ts,tsx,js,jsx apps packages",
    "check:boundaries": "bun scripts/check-cross-app-imports.ts",
    "check:naming": "bun scripts/check-naming.ts",
    "check:no-parent-imports": "bun scripts/check-no-parent-imports.ts",
    "check:api-db-isolation": "bun scripts/check-api-db-isolation.ts",
    "check:constants": "bun scripts/check-constants-centralization.ts",
    "extract:rhymes": "bun scripts/extract-rhymes.ts",
    "check:syncpack": "syncpack lint",
    "depcruise": "depcruise --config .dependency-cruiser.cjs apps packages",
    "ci": "bun scripts/ci.ts",
    "optimize:images": "bun scripts/optimize-images.ts",
    "deps:doctor": "bun scripts/deps-doctor.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@types/bun": "^1.3.14",
    "dependency-cruiser": "17.4.0",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "madge": "8.0.0",
    "neverthrow": "^8.2.0",
    "postgres": "^3.4.9",
    "prettier": "^3.8.3",
    "syncpack": "15.2.0",
    "ts-pattern": "^5.9.0",
    "turbo": "^2.9.14",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1"
  },
  "workspaces": ["apps/*", "packages/*"],
  "overrides": {
    "yaml": "^2.8.3",
    "ws": "^8.20.1",
    "uuid": "^11.1.1"
  },
  "trustedDependencies": ["esbuild", "workerd"]
}
