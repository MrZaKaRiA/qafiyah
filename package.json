{
  "name": "qafiyah",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "db:setup": "./scripts/setup-database.sh",
    "clean:dev": "pkill -f 'qafiyah/.*(astro|wrangler|workerd)' || true",
    "preinstall": "node -e \"if(!String(process.env.npm_config_user_agent||'').startsWith('bun/')){console.error('Use bun (npm/yarn/pnpm not supported). Try: bun install');process.exit(1)}\"",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "types": "turbo run types",
    "lint": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx}\"",
    "test": "turbo run test",
    "knip": "knip",
    "madge": "madge --circular --extensions ts,tsx,js,jsx apps packages",
    "ci": "bun run format && bun run lint && bun run types && bun run test && bun run knip && bun run madge && bun audit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/types": "^19.6.0",
    "@types/node": "^25.0.10",
    "husky": "^9.1.7",
    "knip": "^5.82.1",
    "madge": "8.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "5.8.2"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "yaml": "^2.8.3"
  },
  "trustedDependencies": [
    "esbuild",
    "workerd"
  ]
}
