{
  "name": "qafiyah",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "db:setup": "./scripts/setup-database.sh",
    "clean:dev": "pkill -f 'qafiyah/.*(astro|wrangler|workerd)' || true",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "types": "turbo run types",
    "lint": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx}\"",
    "test": "turbo run test",
    "knip": "knip",
    "madge": "madge --circular --extensions ts,tsx,js,jsx apps packages",
    "ci": "bun run format && bun run lint && bun run types && bun run test && bun run knip && bun run madge && bun audit",
    "optimize:images": "bun scripts/optimize-images.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "knip": "^5.82.1",
    "madge": "8.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "yaml": "^2.8.3"
  },
  "trustedDependencies": [
    "esbuild",
    "workerd"
  ]
}
