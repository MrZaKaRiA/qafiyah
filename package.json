{
  "name": "qafiyah",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:static": "pnpm --filter @qafiyah/web build:static",
    "dev": "./scripts/check-database.sh && turbo run build --filter=@qafiyah/schemas && turbo run dev --filter=@qafiyah/web --filter=@qafiyah/api",
    "dev:test": "pnpm --filter @qafiyah/api dev:test",
    "lint": "turbo run lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,mdx}\"",
    "types": "turbo run types",
    "test": "turbo run test",
    "health": "turbo run health",
    "knip": "knip",
    "madge": "madge --circular --extensions ts,tsx,js,jsx apps packages",
    "prepare": "husky",
    "ci": "pnpm run format && pnpm run lint:fix && pnpm run types",
    "db:setup": "./scripts/setup-database.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/types": "^19.6.0",
    "@types/node": "^25.0.10",
    "husky": "^9.1.7",
    "knip": "^5.82.1",
    "madge": "8.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
