{
  "name": "@qafiyah/web",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:web": "astro build",
    "start": "astro preview",
    "serve": "npx serve dist",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "types": "astro check && tsc --noEmit",
    "health": "astro check",
    "check": "pnpm run type-check && pnpm run lint"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,mdx,css,astro}": [
      "biome check --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx --no -- pnpm lint-staged"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "3.7.2",
    "@qafiyah/db": "workspace:*",
    "@radix-ui/react-slot": "^1.2.0",
    "@tanstack/react-query": "^5.73.3",
    "arabic-count-format": "^1.0.0",
    "astro": "^6.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "nuqs": "^2.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@qafiyah/typescript": "workspace:*",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "cookie": "1.1.1",
    "postcss": "^8.5.3",
    "serve": "^14.2.4",
    "simple-git-hooks": "^2.12.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-debug-screens": "2",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
