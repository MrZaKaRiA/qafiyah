{
  "name": "@qafiyah/web",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:static": "BUILD_API_URL=http://localhost:8787 astro build",
    "start": "astro preview",
    "serve": "npx serve dist",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "types": "astro check && tsc --noEmit",
    "health": "astro check",
    "check": "pnpm run type-check && pnpm run lint"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,mdx,css,astro}": [
      "biome check --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx --no -- pnpm lint-staged"
  },
  "dependencies": {
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@qafiyah/schemas": "workspace:*",
    "@radix-ui/react-slot": "^1.2.0",
    "@tanstack/react-query": "^5.73.3",
    "arabic-count-format": "^1.0.0",
    "astro": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "nuqs": "^2.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7",
    "to-arabic-digits": "^1.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "simple-git-hooks": "^2.12.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-debug-screens": "2",
    "typescript": "^5"
  }
}
