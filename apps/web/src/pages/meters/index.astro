---
import PoemListBody from '@/components/poem-list-body.astro';
import Layout from '@/layouts/layout.astro';
import { CACHE_INDEX } from '@/lib/server/cache';
import { buildTaxonomyIndexView, loadTaxonomyIndex } from '@/lib/taxonomy-pages';

const terms = await loadTaxonomyIndex('meters');
Astro.response.headers.set('Cache-Control', CACHE_INDEX);
const { layout, body } = buildTaxonomyIndexView('meters', terms);
---

<Layout {...layout}>
  <PoemListBody {...body} />
</Layout>
