---
import PoemListBody from '@/components/poem-list-body.astro';
import Layout from '@/layouts/layout.astro';
import { parsePageQuery } from '@/lib/page-numbers';
import { CACHE_LIST } from '@/lib/server/cache';
import { buildTaxonomyTermView, loadTaxonomyTerm } from '@/lib/taxonomy-pages';

const page = parsePageQuery(Astro.url.searchParams.get('page'));
const { slug } = Astro.params;
const load = page === null || !slug ? null : await loadTaxonomyTerm('collections', slug, page);
if (!load) return Astro.rewrite('/404');
Astro.response.headers.set('Cache-Control', CACHE_LIST);
const { layout, body } = buildTaxonomyTermView('collections', load);
---

<Layout {...layout}>
  <PoemListBody {...body} />
</Layout>
