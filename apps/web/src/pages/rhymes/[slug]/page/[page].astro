---
import { SCHEMA_ORG_CONTEXT, SITE_NAME_AR } from '@qafiyah/constants';
import type { RhymeSlug } from '@qafiyah/contracts';
import { SITE_URL } from '@/constants/globals';
import Layout from '@/layouts/Layout.astro';
import {
  fetchRhymePoemPage,
  fetchRhymesWithPoemCount,
  generatePageNumbers,
} from '@/lib/api/static';
import { toArabicDigits } from '@/lib/arabic';

const stripQuotes = (s: string) => s.replace(/"/g, '');

export async function getStaticPaths() {
  const rhymes = await fetchRhymesWithPoemCount();
  const params: Array<{ params: { slug: string; page: string } }> = [];
  for (const rhyme of rhymes) {
    for (const page of generatePageNumbers(rhyme.poemsCount)) {
      params.push({ params: { slug: rhyme.slug, page: page.toString() } });
    }
  }
  return params;
}

const { slug, page } = Astro.params;
const pageNumber = Number.parseInt(page as string, 10);

if (!(slug && Number.isFinite(pageNumber)) || pageNumber < 1) {
  return Astro.redirect('/404');
}

// URL parameter boundary: brand the bare-string slug as a RhymeSlug for the typed API.
const response = await fetchRhymePoemPage(slug as RhymeSlug, page as string);
if (!response) {
  return Astro.redirect('/404');
}

const poems = response.data;
const rhyme = response.meta;
const { totalPages } = response.pagination;
const hasNextPage = pageNumber < totalPages;
const hasPrevPage = pageNumber > 1;
const nextPageUrl = `/rhymes/${slug}/page/${pageNumber + 1}`;
const prevPageUrl = `/rhymes/${slug}/page/${pageNumber - 1}`;
const headerTip = `صـ ${toArabicDigits(pageNumber)} من ${toArabicDigits(totalPages)}`;

const title = `${SITE_NAME_AR} | قصائد على قافية ${rhyme.name} | صفحة (${toArabicDigits(page as string)})`;

const jsonLd = {
  '@context': SCHEMA_ORG_CONTEXT,
  '@type': 'Collection',
  name: `قصائد قافية ${rhyme.name}`,
  url: `${SITE_URL}/rhymes/${slug}/page/${pageNumber}`,
  description: `مجموعة قصائد على قافية ${rhyme.name} - الصفحة ${toArabicDigits(pageNumber)} من ${toArabicDigits(totalPages)}`,
  mainEntityOfPage: {
    '@type': 'CollectionPage',
    name: `قصائد قافية ${rhyme.name}`,
    url: `${SITE_URL}/rhymes/${slug}/page/1`,
  },
  numberOfItems: rhyme.poemsCount,
  itemListElement: poems.map((poem, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: { '@type': 'CreativeWork', name: poem.title, url: `${SITE_URL}/poems/${poem.slug}` },
  })),
};
---

<Layout
  title={title}
  canonical={`/rhymes/${slug}/page/${pageNumber}`}
  ogTitle={title}
  ogUrl={`${SITE_URL}/rhymes/${slug}/page/${pageNumber}`}
  jsonLd={jsonLd}
>
  <section class="w-full flex justify-center items-center flex-col relative overflow-hidden my-14 xs:my-20 lg:my-28">
    <div class="flex justify-start flex-col items-start gap-6 xs:gap-8 sm:gap-14 w-full 3xl:gap-16">
      <h3 class="text-lg xxs:text-2xl xs:text-4xl xl:text-4xl font-medium">
        {`${rhyme.name} (${toArabicDigits(rhyme.poemsCount)} قصيدة)`}
      </h3>
      <div class="grid grid-cols-1 2xl:grid-cols-2 w-full gap-1 sm:gap-4 2xl:gap-6">
        {poems.length > 0 ? poems.map((poem) => (
          <a
            href={`/poems/${poem.slug}`}
            class="hover:cursor-pointer group xxs:gap-2 xs:gap-4 sm:p-8 md:p-10 xs:p-6 p-4 flex-col flex justify-start items-start bg-zinc-100/50 rounded-md border border-zinc-300/50 hover:border-zinc-300/80"
          >
            <p class="text-zinc-800 hover:text-zinc-500 hover:underline duration-300 group-hover:underline-offset-auto group-hover:text-zinc-500 group-hover:underline text-sm xxs:text-base xs:text-2xl sm:text-2xl lg:text-2xl 2xl:text-2xl text-wrap">
              {stripQuotes(poem.title)}
            </p>
            <p class="text-xs xs:text-lg sm:text-xl lg:text-lg text-zinc-600/80 group-hover:text-zinc-500 duration-300 text-wrap">
              {poem.meter.name}
            </p>
          </a>
        )) : (
          <p class="text-center text-zinc-500">لا توجد قصائد لهذه القافية.</p>
        )}
      </div>
      {totalPages > 1 && (
        <nav class="flex flex-row-reverse w-full justify-between items-center gap-4 text-base md:text-lg mt-8">
          {hasNextPage ? (
            <a href={nextPageUrl} class="border py-0.5 px-3 rounded-md border-zinc-200 text-zinc-800">التالي</a>
          ) : (
            <span class="border py-0.5 px-3 rounded-md border-zinc-200 cursor-not-allowed text-zinc-500" aria-disabled="true">التالي</span>
          )}
          <p class="text-zinc-500 text-base">{headerTip}</p>
          {hasPrevPage ? (
            <a href={prevPageUrl} class="border py-0.5 px-3 rounded-md border-zinc-200 text-zinc-800">السابق</a>
          ) : (
            <span class="border py-0.5 px-3 rounded-md border-zinc-200 cursor-not-allowed text-zinc-500" aria-disabled="true">السابق</span>
          )}
        </nav>
      )}
    </div>
  </section>
</Layout>
