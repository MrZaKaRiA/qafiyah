---
import { poemSlugSchema } from '@qafiyah/contracts';
import * as v from 'valibot';
import { PoemDisplay } from '@/components/poem-display';
import Layout from '@/layouts/layout.astro';
import { fetchAllPoemSlugs } from '@/lib/api/static/poems';
import { loadPoemPage } from '@/lib/poem-page';

export async function getStaticPaths() {
  const slugsResult = await fetchAllPoemSlugs();
  if (slugsResult.isErr()) {
    throw new Error(`fetchAllPoemSlugs failed: ${JSON.stringify(slugsResult.error)}`);
  }
  return slugsResult.value.map((poemSlug) => ({ params: { slug: poemSlug } }));
}

const parsed = v.safeParse(poemSlugSchema, Astro.params.slug);
if (!parsed.success) {
  return Astro.redirect('/404');
}
const slug = parsed.output;
const pageDataResult = await loadPoemPage(slug);

if (pageDataResult.isErr()) {
  if (pageDataResult.error.kind === 'not_found') return Astro.redirect('/404');
  throw new Error(`loadPoemPage failed: ${JSON.stringify(pageDataResult.error)}`);
}

const { poem, layout: seo } = pageDataResult.value;
---

<Layout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical={seo.canonical}
  ogType="article"
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  twitterTitle={seo.twitterTitle}
  twitterDescription={seo.twitterDescription}
  jsonLd={seo.jsonLd}
>
  <PoemDisplay
    client:idle
    title={poem.title}
    poet={poem.poet}
    era={poem.era}
    meter={poem.meter}
    theme={poem.theme}
    verses={poem.verses}
    verseCount={poem.verseCount}
    relatedPoems={poem.relatedPoems}
  />
</Layout>
