---
import { PoemDisplay } from '@/components/poem/poem-display';
import Layout from '@/layouts/Layout.astro';
import { fetchAllPoemSlugsFast } from '@/lib/api/static';
import { loadPoemPage } from '@/lib/poem-page';

export async function getStaticPaths() {
  const slugs = await fetchAllPoemSlugsFast();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const pageData = await loadPoemPage(slug as string);

if (!pageData) {
  return Astro.redirect('/404/');
}

const { poem, layout: seo } = pageData;
---

<Layout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogUrl={seo.ogUrl}
  twitterTitle={seo.twitterTitle}
  twitterDescription={seo.twitterDescription}
  jsonLd={seo.jsonLd}
>
  <PoemDisplay
    client:idle
    clearTitle={poem.clearTitle}
    metadata={poem.metadata}
    verses={poem.processedContent.verses}
    verseCount={poem.processedContent.verseCount}
    relatedPoems={poem.relatedPoems}
  />
</Layout>
