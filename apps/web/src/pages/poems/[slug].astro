---
import { poemSlugSchema } from '@qafiyah/contracts';
import * as v from 'valibot';
import { PoemDisplay } from '@/components/poem/poem-display';
import Layout from '@/layouts/layout.astro';
import { fetchAllPoemSlugs } from '@/lib/api/static/poems';
import { loadPoemPage } from '@/lib/poem-page';

export async function getStaticPaths() {
  const slugs = await fetchAllPoemSlugs();
  return slugs.map((poemSlug) => ({ params: { slug: poemSlug } }));
}

const parsed = v.safeParse(poemSlugSchema, Astro.params.slug);
if (!parsed.success) {
  return Astro.redirect('/404');
}
const slug = parsed.output;
const pageData = await loadPoemPage(slug);

if (!pageData) {
  return Astro.redirect('/404');
}

const { poem, layout: seo } = pageData;
---

<Layout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogUrl={seo.ogUrl}
  twitterTitle={seo.twitterTitle}
  twitterDescription={seo.twitterDescription}
  jsonLd={seo.jsonLd}
>
  <PoemDisplay
    client:idle
    title={poem.title}
    poet={poem.poet}
    era={poem.era}
    meter={poem.meter}
    theme={poem.theme}
    verses={poem.verses}
    verseCount={poem.verseCount}
    relatedPoems={poem.relatedPoems}
  />
</Layout>
