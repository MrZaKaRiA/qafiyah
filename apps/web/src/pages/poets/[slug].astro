---
import type { PoetSlug } from '@qafiyah/contracts';
import { formatArabicCount } from 'arabic-count-format';
import PoemListBody from '@/components/poem-list-body.astro';
import { POEMS_NOUN_FORMS, SCHEMA_ORG_CONTEXT, SITE_NAME_AR, SITE_URL } from '@/constants';
import Layout from '@/layouts/layout.astro';
import { toArabicDigits } from '@/lib/arabic';
import { breadcrumbListJsonLd } from '@/lib/breadcrumbs';
import { parsePageQuery } from '@/lib/page-numbers';
import { derivePagination } from '@/lib/pagination';
import { CACHE_LIST } from '@/lib/server/cache';
import { listPoems } from '@/lib/server/poems';
import { getPoet } from '@/lib/server/poets';
import { poemUrl, poetsUrl, poetUrl } from '@/lib/urls';

const page = parsePageQuery(Astro.url.searchParams.get('page'));
const { slug: slugParam } = Astro.params;
const poetSlug = slugParam as PoetSlug | undefined;
const [poet, list] =
  page === null || !poetSlug
    ? [null, null]
    : await Promise.all([getPoet(poetSlug), listPoems({ poetSlugs: [poetSlug] }, page)]);
if (!(poet && list)) return Astro.rewrite('/404');
Astro.response.headers.set('Cache-Control', CACHE_LIST);
const { poems, pagination } = list;
const slug = poet.slug;
const pageNumber = pagination.page;
const pag = derivePagination(pagination, (p) => poetUrl(slug, p));

const poemsLabel = formatArabicCount({
  count: poet.poemsCount,
  nounForms: POEMS_NOUN_FORMS,
});

const title = `${SITE_NAME_AR} | ديوان «${poet.name}»`;
const description = `ديوان الشاعر ${poet.name} على ${SITE_NAME_AR} — الصفحة ${toArabicDigits(pageNumber)} من ${toArabicDigits(pag.totalPages)}، عدد القصائد: ${toArabicDigits(poet.poemsCount)}.`;

const personJsonLd = {
  '@context': SCHEMA_ORG_CONTEXT,
  '@type': 'Person',
  name: poet.name,
  url: `${SITE_URL}${poetUrl(slug)}`,
  description: `ديوان ${poet.name} (${poemsLabel})`,
  mainEntityOfPage: {
    '@type': 'CollectionPage',
    name: `ديوان ${poet.name}`,
    url: `${SITE_URL}${poetUrl(slug)}`,
  },
  workExample: poems.slice(0, 10).map((poem) => ({
    '@type': 'CreativeWork',
    name: poem.title,
    description: `قصيدة (${poem.title}) على ${poem.meter.name}`,
    url: `${SITE_URL}${poemUrl(poem.slug)}`,
  })),
};

const crumbItems = [
  { name: SITE_NAME_AR, path: '/' },
  { name: 'الشعراء', path: poetsUrl() },
  { name: poet.name, path: poetUrl(slug) },
];
const crumbsJsonLd = breadcrumbListJsonLd(crumbItems);

const items = poems.map((poem) => ({
  title: poem.title,
  subtitle: poem.meter.name,
  href: poemUrl(poem.slug),
}));
---

<Layout
  title={title}
  description={description}
  canonical={poetUrl(slug, pageNumber)}
  prevUrl={pag.hasPrevPage ? pag.prevPageUrl : undefined}
  nextUrl={pag.hasNextPage ? pag.nextPageUrl : undefined}
  ogTitle={`${SITE_NAME_AR} | ديوان ${poet.name}`}
  ogDescription={description}
  twitterTitle={`${SITE_NAME_AR} | ديوان ${poet.name}`}
  twitterDescription={description}
  jsonLd={[personJsonLd, crumbsJsonLd]}
>
  <PoemListBody
    heading={`${poet.name} (${toArabicDigits(poet.poemsCount)} قصيدة)`}
    crumbItems={crumbItems}
    items={items}
    emptyText="لا توجد قصائد لهذا الشاعر."
    pagination={pag}
  />
</Layout>
