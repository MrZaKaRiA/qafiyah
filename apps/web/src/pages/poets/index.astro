---
import { MAX_QUERY_LENGTH } from '@qafiyah/constants';
import type { EraSlug } from '@qafiyah/contracts';
import PoemListBody from '@/components/poem-list-body.astro';
import { SCHEMA_ORG_CONTEXT, SITE_NAME_AR, SITE_URL } from '@/constants';
import Layout from '@/layouts/layout.astro';
import { toArabicDigits } from '@/lib/arabic';
import { breadcrumbListJsonLd } from '@/lib/breadcrumbs';
import { parsePageQuery } from '@/lib/page-numbers';
import { derivePagination } from '@/lib/pagination';
import { CACHE_LIST } from '@/lib/server/cache';
import { getPoetsPage } from '@/lib/server/poets';
import { allEras } from '@/lib/server/taxonomies';
import { poetsUrl, poetUrl } from '@/lib/urls';

const page = parsePageQuery(Astro.url.searchParams.get('page'));
if (page === null) return Astro.rewrite('/404');

const rawEra = (Astro.url.searchParams.get('era') ?? '').trim();
const rawQuery = (Astro.url.searchParams.get('q') ?? '').trim().slice(0, MAX_QUERY_LENGTH);

const eras = await allEras();
const activeEra = rawEra ? eras.find((era) => era.slug === rawEra) : undefined;
// A non-empty era that matches no known era is a bad URL → 404.
if (rawEra && !activeEra) return Astro.rewrite('/404');

const eraFilter = activeEra?.slug as EraSlug | undefined;
const queryFilter = rawQuery || undefined;

const data = await getPoetsPage(page, { era: eraFilter, q: queryFilter });
if (!data) return Astro.rewrite('/404');
Astro.response.headers.set('Cache-Control', CACHE_LIST);

const { poets, pagination } = data;
const pageNumber = pagination.page;
const totalPoets = pagination.totalItems;
const isFiltered = Boolean(eraFilter || queryFilter);
const eraParam = rawEra || undefined;

const pag = derivePagination(pagination, (p) =>
  poetsUrl({ page: p, era: eraParam, q: queryFilter })
);

function buildHeading(): string {
  if (activeEra) return `شعراء العصر ال${activeEra.name} (${toArabicDigits(totalPoets)} شاعر)`;
  if (queryFilter) return `نتائج البحث عن «${queryFilter}» (${toArabicDigits(totalPoets)} شاعر)`;
  return `جميع الشعراء (${toArabicDigits(totalPoets)} شاعر)`;
}
const heading = buildHeading();
const emptyText = isFiltered ? 'لا يوجد شعراء مطابقون' : 'لا يوجد المزيد من الشعراء';

const title = `${SITE_NAME_AR} | الشعراء`;
const description = `الشعراء على ${SITE_NAME_AR} — الصفحة ${toArabicDigits(pageNumber)} من ${toArabicDigits(pag.totalPages)}. تصفح دواوين ${toArabicDigits(totalPoets)} شاعرٍ من العصر الجاهلي إلى الحديث.`;

const collectionJsonLd = {
  '@context': SCHEMA_ORG_CONTEXT,
  '@type': 'CollectionPage',
  name: 'قائمة الشعراء',
  url: `${SITE_URL}${poetsUrl({ page: pageNumber })}`,
  description: `قائمة بجميع الشعراء في موقع ${SITE_NAME_AR} - الصفحة ${toArabicDigits(pageNumber)} من ${toArabicDigits(pag.totalPages)}`,
  isPartOf: { '@type': 'WebSite', name: SITE_NAME_AR, url: SITE_URL },
  numberOfItems: totalPoets,
  itemListElement: poets.map((poet, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: { '@type': 'Person', name: poet.name, url: `${SITE_URL}${poetUrl(poet.slug ?? '')}` },
  })),
};

const crumbItems = [
  { name: SITE_NAME_AR, path: '/' },
  { name: 'الشعراء', path: poetsUrl() },
];
const crumbsJsonLd = breadcrumbListJsonLd(crumbItems);

const chipBase =
  'rounded-md border px-3 py-1 text-sm transition-colors duration-200 hover:cursor-pointer';
const chipActive = 'border-zinc-800 bg-zinc-800 text-zinc-50';
const chipIdle = 'border-zinc-300/50 bg-white text-zinc-700 hover:border-zinc-300';

const chips = [
  { label: 'الكل', href: poetsUrl({ q: queryFilter }), isActive: !activeEra },
  ...eras.map((era) => ({
    label: era.name,
    href: poetsUrl({ era: era.slug, q: queryFilter }),
    isActive: era.slug === activeEra?.slug,
  })),
];

const items = poets.map((poet) => ({
  title: poet.name,
  subtitle: `${toArabicDigits(poet.poemsCount)} قصيدة`,
  href: poetUrl(poet.slug ?? ''),
}));
---

<Layout
  title={title}
  description={description}
  canonical={poetsUrl({ page: pageNumber, era: eraParam, q: queryFilter })}
  robotsIndex={!isFiltered}
  prevUrl={pag.hasPrevPage ? pag.prevPageUrl : undefined}
  nextUrl={pag.hasNextPage ? pag.nextPageUrl : undefined}
  jsonLd={[collectionJsonLd, crumbsJsonLd]}
>
  <PoemListBody
    heading={heading}
    crumbItems={pageNumber > 1 ? crumbItems : undefined}
    items={items}
    emptyText={emptyText}
    pagination={pag}
  >
    <form method="GET" action="/poets" role="search" class="flex w-full flex-col gap-4">
      {activeEra && <input type="hidden" name="era" value={activeEra.slug} />}
      <div class="flex w-full flex-row-reverse gap-2">
        <input
          type="search"
          name="q"
          value={queryFilter ?? ''}
          maxlength={MAX_QUERY_LENGTH}
          placeholder="ابحث عن شاعر بالاسم"
          class="flex-1 rounded-md border border-zinc-300/50 bg-white px-4 py-2 text-base text-zinc-800 outline-none focus-visible:border-zinc-400"
        />
        <button
          type="submit"
          class="rounded-md border border-zinc-800 bg-zinc-800 px-5 py-2 text-base text-zinc-50 hover:cursor-pointer"
        >
          بحث
        </button>
      </div>
      <div class="flex flex-row-reverse flex-wrap gap-2">
        {chips.map((chip) => (
          <a href={chip.href} class:list={[chipBase, chip.isActive ? chipActive : chipIdle]}>
            {chip.label}
          </a>
        ))}
      </div>
    </form>
  </PoemListBody>
</Layout>
