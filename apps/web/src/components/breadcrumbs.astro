---
import type { BreadcrumbItem } from '@/lib/breadcrumbs';

interface Props {
  items: readonly BreadcrumbItem[];
}

const { items } = Astro.props;
---
<nav aria-label="مسار التصفح" class="w-full text-xs xs:text-sm text-zinc-500">
  <ol class="flex flex-row flex-wrap items-center justify-start gap-1.5" dir="rtl">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && <span aria-hidden="true" class="text-zinc-400">›</span>}
        {i === items.length - 1 ? (
          <span aria-current="page" class="text-zinc-700">{item.name}</span>
        ) : (
          <a href={item.path} class="hover:underline hover:text-zinc-700">{item.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>
