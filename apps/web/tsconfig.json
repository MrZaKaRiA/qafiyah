{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "to-arabic-digits": ["./src/utils/texts/arabic-digits.ts"],
      "*": ["./*"]
    },
    "jsx": "react-jsx",
    "strictNullChecks": true
  },
  "include": ["src", ".astro/types.d.ts"],
  "exclude": ["node_modules", "dist", ".astro"]
}
