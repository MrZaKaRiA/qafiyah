{
  "extends": "@qafiyah/typescript/bun.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"],
  "watchOptions": {
    "excludeDirectories": ["node_modules", "dist"],
    "excludeFiles": ["dist/**/*"],
    "fallbackPolling": "dynamicPriority"
  }
}
