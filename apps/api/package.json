    "@qafiyah/db": "workspace:*",
    "@qafiyah/typescript": "workspace:*",
    "hono": "^4.12.19",
    "neverthrow": "^8.2.0",
    "ts-pattern": "^5.9.0",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.6",
