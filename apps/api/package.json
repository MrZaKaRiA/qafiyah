{
  "name": "@qafiyah/api",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:test": "wrangler dev --env test",
    "build": "pnpm run build:deps && wrangler build",
    "build:deps": "pnpm --filter @qafiyah/db build",
    "deploy": "wrangler deploy --minify",
    "types": "tsc --noEmit --pretty",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@qafiyah/constants": "workspace:*",
    "@qafiyah/db": "workspace:*",
    "@qafiyah/typescript": "workspace:*",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.11.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@types/node": "^25.0.10",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "vitest": "^2.1.8",
    "wrangler": "^4.59.1"
  },
  "type": "module",
  "types": "./src/app.ts"
}
