{
  "name": "@qafiyah/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export --platform ios --output-dir dist",
    "types": "tsc --noEmit --pretty",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@qafiyah/constants": "workspace:*",
    "expo": "^56.0.0",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@qafiyah/typescript": "workspace:*",
    "@types/react": "^19.2.14",
    "babel-preset-expo": "56.0.10",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  },
  "expo": {
    "install": {
      "exclude": ["expo"]
    }
  }
}
