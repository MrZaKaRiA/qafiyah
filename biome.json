{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.next",
      "!**/build",
      "!**/.turbo",
      "!**/coverage",
      "!**/*.min.js",
      "!**/bun.lock",
      "!**/dumps",
      "!**/env.d.ts",
      "!**/worker-configuration.d.ts",
      "!apps/web/.astro"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "useEditorconfig": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto"
  },
  "linter": {
    "enabled": true,
    "domains": {
      "react": "recommended",
      "test": "all"
    },
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": true,
        "useSemanticElements": "off",
        "useAriaActivedescendantWithTabindex": "off",
        "useFocusableInteractive": "off",
        "useButtonType": "error",
        "noNoninteractiveElementToInteractiveRole": "off",
        "noNoninteractiveTabindex": "off",
        "useValidAriaProps": "warn",
        "useAriaPropsForRole": "warn",
        "useKeyWithClickEvents": "off",
        "useKeyWithMouseEvents": "off",
        "noStaticElementInteractions": "error",
        "useValidAutocomplete": "warn"
      },
      "complexity": {
        "recommended": true,
        "noBannedTypes": "error",
        "noUselessTypeConstraint": "error",
        "noUselessConstructor": "error",
        "noUselessLoneBlockStatements": "error",
        "noUselessRename": "error",
        "noUselessSwitchCase": "error",
        "noUselessTernary": "error",
        "noUselessThisAlias": "error",
        "noUselessFragments": "error",
        "noUselessEmptyExport": "error",
        "noUselessStringConcat": "error",
        "noUselessUndefinedInitialization": "error",
        "noStaticOnlyClass": "error",
        "noThisInStatic": "error",
        "noFlatMapIdentity": "error",
        "noEmptyTypeParameters": "error",
        "noVoid": "error",
        "useArrowFunction": "error",
        "useDateNow": "error",
        "useFlatMap": "error",
        "useOptionalChain": "error",
        "useRegexLiterals": "error",
        "useSimplifiedLogicExpression": "error",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "recommended": true,
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedPrivateClassMembers": "error",
        "noUnusedLabels": "error",
        "noPrecisionLoss": "error",
        "noConstantMathMinMaxClamp": "error",
        "noInvalidUseBeforeDeclaration": "error",
        "noStringCaseMismatch": "error",
        "noSwitchDeclarations": "error",
        "noUnsafeFinally": "error",
        "noUnsafeOptionalChaining": "error",
        "noVoidTypeReturn": "error",
        "noVoidElementsWithChildren": "error",
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error",
        "useIsNan": "error",
        "useJsxKeyInIterable": "error",
        "useValidForDirection": "error",
        "useValidTypeof": "error",
        "useYield": "error",
        "useJsonImportAttributes": "error",
        "noNodejsModules": "off",
        "useImportExtensions": "off",
        "noUndeclaredDependencies": "off",
        "noUnresolvedImports": "off",
        "noNestedComponentDefinitions": "error",
        "useUniqueElementIds": "error",
        "noUnknownFunction": "error",
        "noUnknownProperty": "error",
        "noUnknownPseudoClass": "error",
        "noUnknownUnit": "error"
      },
      "performance": {
        "recommended": true,
        "noAccumulatingSpread": "error",
        "noDelete": "error",
        "noReExportAll": "warn",
        "noBarrelFile": "warn",
        "useTopLevelRegex": "warn"
      },
      "security": {
        "recommended": true,
        "noDangerouslySetInnerHtml": "error",
        "noDangerouslySetInnerHtmlWithChildren": "error",
        "noGlobalEval": "error",
        "noBlankTarget": "error"
      },
      "style": {
        "recommended": true,
        "noParameterAssign": "error",
        "noNonNullAssertion": "error",
        "noInferrableTypes": "error",
        "noNamespace": "error",
        "noUselessElse": "error",
        "noNegationElse": "warn",
        "noNestedTernary": "error",
        "noShoutyConstants": "warn",
        "noSubstr": "error",
        "noParameterProperties": "error",
        "noCommonJs": "error",
        "noEnum": "off",
        "noDefaultExport": "off",
        "noProcessEnv": "error",
        "useConst": "error",
        "useImportType": "error",
        "useExportType": "error",
        "useAsConstAssertion": "error",
        "useEnumInitializers": "error",
        "useLiteralEnumMembers": "error",
        "useDefaultParameterLast": "error",
        "useNumberNamespace": "error",
        "useNodejsImportProtocol": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error",
        "useTemplate": "error",
        "useShorthandAssign": "error",
        "useShorthandFunctionType": "error",
        "useSingleVarDeclarator": "error",
        "useExponentiationOperator": "error",
        "useExplicitLengthCheck": "error",
        "useConsistentArrayType": { "level": "error", "options": { "syntax": "shorthand" } },
        "useConsistentBuiltinInstantiation": "error",
        "useCollapsedElseIf": "error",
        "useNamingConvention": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@qafiyah/web": "Cross-app imports are forbidden. Move shared code to packages/*.",
              "@qafiyah/api": "Cross-app imports are forbidden. apps/web reaches the API via oRPC over HTTP; apps/bot uses fetch.",
              "@qafiyah/bot": "Cross-app imports are forbidden. Move shared code to packages/*."
            }
          }
        },
        "useForOf": "error",
        "useFragmentSyntax": "error",
        "useTrimStartEnd": "error",
        "useSymbolDescription": "error",
        "useSelfClosingElements": "off"
      },
      "suspicious": {
        "recommended": true,
        "noExplicitAny": "error",
        "noArrayIndexKey": "error",
        "noConsole": { "level": "warn", "options": { "allow": ["error", "warn"] } },
        "noSkippedTests": "error",
        "noFocusedTests": "error",
        "noDuplicateTestHooks": "error",
        "noMisplacedAssertion": "error",
        "noDebugger": "error",
        "noDoubleEquals": "error",
        "noVar": "error",
        "noImplicitAnyLet": "error",
        "noEvolvingTypes": "error",
        "noTsIgnore": "error",
        "noUnsafeDeclarationMerging": "error",
        "noUnsafeNegation": "error",
        "noConfusingVoidType": "error",
        "noConfusingLabels": "error",
        "noAssignInExpressions": "error",
        "noAsyncPromiseExecutor": "error",
        "noEmptyBlockStatements": "error",
        "noEmptyInterface": "error",
        "noFallthroughSwitchClause": "error",
        "noGlobalIsFinite": "error",
        "noGlobalIsNan": "error",
        "noImportAssign": "error",
        "noImportCycles": "error",
        "noIrregularWhitespace": "error",
        "noLabelVar": "error",
        "noMisleadingCharacterClass": "error",
        "noMisleadingInstantiator": "error",
        "noMisrefactoredShorthandAssign": "error",
        "noNonNullAssertedOptionalChain": "error",
        "noOctalEscape": "error",
        "noPrototypeBuiltins": "error",
        "noRedeclare": "error",
        "noSelfCompare": "error",
        "noShadowRestrictedNames": "error",
        "noSparseArray": "error",
        "noTemplateCurlyInString": "error",
        "noThenProperty": "error",
        "noUnassignedVariables": "error",
        "noUnusedExpressions": "error",
        "noConstEnum": "error",
        "noConstantBinaryExpressions": "error",
        "noApproximativeNumericConstant": "error",
        "noDocumentCookie": "error",
        "noDuplicateProperties": "error",
        "noShorthandPropertyOverrides": "error",
        "useAwait": "error",
        "useAdjacentOverloadSignatures": "error",
        "useDefaultSwitchClauseLast": "error",
        "useErrorMessage": "error",
        "useGetterReturn": "error",
        "useGuardForIn": "error",
        "useIsArray": "error",
        "useIterableCallbackReturn": "error",
        "useNamespaceKeyword": "error",
        "useNumberToFixedDigitsArgument": "error",
        "useStaticResponseMethods": "error",
        "noUnknownAtRules": "off"
      },
      "nursery": {
        "noFloatingPromises": "error",
        "noMisusedPromises": "error",
        "useAwaitThenable": "error",
        "noShadow": "error",
        "noEqualsToNull": "error",
        "noImpliedEval": "error",
        "noDuplicateEnumValues": "error",
        "noDuplicatedSpreadProps": "error",
        "useConsistentEnumValueType": "error",
        "useExhaustiveSwitchCases": "error",
        "useNullishCoalescing": "error",
        "useArraySortCompare": "error",
        "useErrorCause": "error",
        "useSortedClasses": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "es5",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false,
      "attributePosition": "auto",
      "expand": "auto"
    },
    "globals": []
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedKeys": "off"
      }
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none",
      "expand": "auto"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["apps/web/**"],
      "linter": {
        "rules": {
          "nursery": {
            "useSortedClasses": {
              "level": "warn",
              "options": {
                "attributes": ["class", "className"],
                "functions": ["clsx", "cn", "tw"]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/web/**/*.astro"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off",
            "noUnusedFunctionParameters": "off"
          },
          "style": {
            "noDefaultExport": "off",
            "noProcessEnv": "off"
          },
          "nursery": {
            "noFloatingPromises": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/api/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noNodejsModules": "error"
          }
        }
      }
    },
    {
      "includes": ["apps/bot/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/worker/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          },
          "style": {
            "noProcessEnv": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/env.ts",
        "**/src/env.ts",
        "**/src/server.ts",
        "**/vitest.setup.ts",
        "**/vitest.config.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noProcessEnv": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noEmptyBlockStatements": "off",
            "useAwait": "off"
          },
          "style": {
            "noNonNullAssertion": "off",
            "noProcessEnv": "off"
          },
          "nursery": {
            "noFloatingPromises": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.config.{ts,js,mjs}", "**/scripts/**"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off",
            "noProcessEnv": "off"
          },
          "suspicious": {
            "noConsole": "off"
          },
          "correctness": {
            "noNodejsModules": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/*/src/index.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off",
            "noReExportAll": "off"
          }
        }
      }
    }
  ]
}
