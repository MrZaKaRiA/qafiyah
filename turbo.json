{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "!dist/**/*.tsbuildinfo", "out/**"]
    },
    "lint": {
      "dependsOn": [],
      "inputs": ["src/**/*.{ts,tsx,js,jsx}", "*.{js,ts,json}"],
      "outputs": []
    },
    "types": {
      "dependsOn": ["^types"],
      "inputs": ["src/**/*.{ts,tsx}", "*.{ts,json}", "tsconfig.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{ts,tsx}", "*.{ts,json}", "vitest.config.*"],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  },
  "globalDependencies": ["**/.env.*local", ".env", "turbo.json", "package.json"]
}
