{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "!dist/**/*.tsbuildinfo", "out/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["src/**/*.{ts,tsx,js,jsx}", "*.{js,ts,json}"],
      "outputs": []
    },
    "health": {
      "dependsOn": ["^health"],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx,astro}",
        "*.{js,ts,json,mjs}",
        "tsconfig.json",
        "astro.config.*"
      ],
      "outputs": []
    },
    "types": {
      "dependsOn": ["^types"],
      "inputs": ["src/**/*.{ts,tsx}", "*.{ts,json}", "tsconfig.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{ts,tsx}", "*.{ts,json}", "vitest.config.*"],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:test": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{ts,tsx}", "*.{ts,json}"],
      "outputs": ["**/*.tsbuildinfo"]
    },
    "clean": {
      "cache": false,
      "inputs": [],
      "outputs": []
    }
  },
  "globalDependencies": ["**/.env.*local", ".env", "turbo.json", "package.json"]
}
