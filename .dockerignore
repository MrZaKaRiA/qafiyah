# Git
.git
.gitignore
.gitattributes

# Dependencies (installed fresh inside the image)
**/node_modules
.pnp
.pnp.js

# Build outputs & caches (produced inside the image; never copy host copies)
**/dist
**/.astro
**/.turbo
**/.wrangler
**/*.tsbuildinfo
.next
out
build

# Tests & coverage (not needed at build or runtime)
**/coverage
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/vitest.config.*

# Env files (secrets/local config; never bake into an image)
.env
.env.local
.env.*.local
.dev.vars

# Tooling / IDE / CI / docs
.vscode
.idea
.husky
.github
docs
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Secrets / local backups
*.pem
.db_setup_backups

# Heavy / irrelevant: DB dumps are bind-mounted at runtime, never built in.
dumps
tools/**/venv
tools/**/.venv

# Misc
.vercel
docker-compose.override.yml
